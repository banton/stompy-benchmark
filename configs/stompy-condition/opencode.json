{
  "$schema": "https://opencode.ai/config.json",
  "provider": "anthropic",
  "model": "claude-opus-4-6",
  "plugins": {
    "token-tracker": {
      "enabled": true,
      "output": "token-log.jsonl",
      "format": "jsonl"
    }
  },
  "mcpServers": {
    "stompy": {
      "type": "sse",
      "url": "https://api.stompy.ai/mcp/sse",
      "headers": {
        "Authorization": "Bearer ${STOMPY_API_KEY}"
      }
    }
  }
}
